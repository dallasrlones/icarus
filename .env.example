# ─── REQUIRED ─────────────────────────────────────────────────────────
# Cursor API key. Generate one at:
#   https://cursor.com/dashboard/integrations
CURSOR_API_KEY=crsr_replace_me

# ─── OPTIONAL — agent visibility ──────────────────────────────────────
# Directory the agent can see (mounted at /workspace inside the
# server container; used as `cwd` for `cursor-agent` when running
# project-scoped chats / tasks). Defaults to `./.workspace` (an empty
# placeholder dir in the repo) so Docker doesn't trigger macOS TCC
# prompts for Documents/Desktop. Set this to whatever folder of code
# you want the agent rooted at.
# WORKSPACE_DIR=/Users/you/projects

# Cursor model id; leave unset for cursor-agent's default.
# CURSOR_MODEL=composer-2

# Set to "true" to let the agent write files (passes --force to
# cursor-agent). Default false — the agent can read but not write.
# CURSOR_ALLOW_FILE_WRITES=false

# Log every cursor-agent invocation + raw stdio. Useful for debugging
# command-emission, very noisy. Set to anything truthy.
# CURSOR_DEBUG=1

# ─── OPTIONAL — client connection ─────────────────────────────────────
# URL the web/native client uses to reach the server. Default is
# http://localhost:4000 — only override if running the server on a
# different host or behind a reverse proxy.
# EXPO_PUBLIC_API_URL=http://localhost:4000

# ─── OPTIONAL — Voice (Phase 15) ──────────────────────────────────────
# Self-hosted STT (Whisper) and TTS (XTTS-v2) endpoints. Leave unset
# to disable voice — the mic button hides and `/v1/voice/health`
# reports `available: false`. Reference services live in the sister
# repo `tools/{stt,tts}-service` (Jetson-targeted; any HTTP-compatible
# service works).
# VOICE_STT_URL=http://your-jetson.lan:8001
# VOICE_TTS_URL=http://your-jetson.lan:8002
# VOICE_TTS_VOICE=default
# VOICE_TTS_LANGUAGE=en

# ─── OPTIONAL — Auth (Phase 22) ───────────────────────────────────────
# Auth is mandatory but everything below has sensible defaults. The
# first boot seeds an `admin` / `changeme` user and forces a password
# change on first sign-in. See docs/AUTH.md for the full contract.
#
# JWT signing key. When unset, the server writes a fresh 48-byte
# random key to `<dataRoot>/.jwt-secret` on first boot and reuses it.
# Set explicitly to manage rotation yourself (must be ≥ 16 chars).
# JWT_SECRET=
#
# Token lifetime. Accepts anything `jsonwebtoken` accepts:
# "15m", "24h", "7d", a number of seconds, etc.
# JWT_EXPIRES_IN=7d
#
# Override the bootstrap admin's username / password (only used the
# very first boot, when the users table is empty).
# AUTH_BOOTSTRAP_USERNAME=admin
# AUTH_BOOTSTRAP_PASSWORD=changeme

# ─── OPTIONAL — Cursor Usage Pill (Phase 17) ──────────────────────────
# Path to the Cursor desktop's `state.vscdb` (read-only mount). Used
# by the "usage pill" in the sidebar to show your current Cursor
# token spend. Leave unset to hide the pill.
#
# macOS:    ~/Library/Application Support/Cursor/User/globalStorage/state.vscdb
# Linux:    ~/.config/Cursor/User/globalStorage/state.vscdb
# Windows:  %APPDATA%\Cursor\User\globalStorage\state.vscdb
#
# When running natively (./scripts/dev-native.sh) this is auto-detected
# on macOS. When running in Docker, the docker-compose mount handles it
# (override CURSOR_DESKTOP_HOST_DIR if you're not on macOS).
# CURSOR_DESKTOP_HOST_DIR=
